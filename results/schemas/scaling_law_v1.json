{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gwailee/uid/blob/main/results/schemas/scaling_law_v1.json",
  "title": "UID Scaling-Law Experiment Result (v1)",
  "description": "Per-(family, scale, seed) results from experiments/run_scaling_law.py. Conforms to the contract in results/README.md §Schema 2.",
  "type": "object",
  "additionalProperties": false,
  "required": ["experiment", "timestamp", "n_results", "results"],
  "properties": {
    "experiment": {
      "type": "string",
      "pattern": "^scaling_law_v",
      "description": "Producing-experiment tag; current canonical value: 'scaling_law_v2.1'."
    },
    "timestamp": {
      "type": "string",
      "description": "Human-readable timestamp; format 'YYYY-MM-DD HH:MM:SS'."
    },
    "n_results": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/scalingPoint" }
    }
  },
  "$defs": {
    "scalingPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_family",
        "scale_name",
        "non_emb_params",
        "train_flops",
        "final_train_loss",
        "final_eval_loss",
        "final_eval_ppl",
        "wall_clock_seconds",
        "seed",
        "v21_keys"
      ],
      "properties": {
        "model_family": {
          "type": "string",
          "enum": [
            "transformer",
            "transformer_plus_tricks",
            "cid_full",
            "cid_full_no_et",
            "cid_full_fft_noise"
          ],
          "description": "One of the five v2.1 supported families (see experiments/run_scaling_law.py VALID_FAMILIES)."
        },
        "scale_name": {
          "type": "string",
          "enum": ["10M", "30M", "100M", "300M", "1B"]
        },
        "non_emb_params": {
          "type": "integer",
          "minimum": 1
        },
        "train_flops": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "final_train_loss": { "type": "number" },
        "final_eval_loss": { "type": "number" },
        "final_eval_ppl": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "wall_clock_seconds": {
          "type": "number",
          "minimum": 0
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "v21_keys": { "$ref": "#/$defs/v21Keys" }
      }
    },
    "v21Keys": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "scale",
        "vocab_size",
        "max_seq_len",
        "noise_type",
        "noise_tau",
        "noise_beta",
        "use_et_symmetric"
      ],
      "properties": {
        "family": { "type": "string" },
        "scale": { "type": "string" },
        "vocab_size": { "type": "integer", "minimum": 1 },
        "max_seq_len": { "type": "integer", "minimum": 1 },
        "noise_type": {
          "type": "string",
          "enum": ["ou", "fft"]
        },
        "noise_tau": { "type": "number", "exclusiveMinimum": 0 },
        "noise_beta": { "type": "number", "minimum": 0 },
        "use_et_symmetric": { "type": "boolean" }
      }
    }
  }
}
