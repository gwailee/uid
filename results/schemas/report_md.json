{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gwailee/uid/blob/main/results/schemas/report_md.json",
  "title": "UID Phase REPORT.md Front-Matter (v1)",
  "description": "REPORT.md is human-prose markdown so it does not have a single canonical JSON schema. However, a sidecar `REPORT.front-matter.json` file SHOULD accompany each REPORT.md to make pass/fail outcomes machine-readable. This schema describes that sidecar file. The producing script is `scripts/extract_report_front_matter.py` (which parses REPORT.md §1 and §2 into this JSON). Conforms to results/README.md §Schema 6.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase",
    "uid_version",
    "uid_commit_hash",
    "report_path",
    "report_sha256",
    "phase_status",
    "falsification_scorecard",
    "headline_summary",
    "aggregate_counts",
    "signatories"
  ],
  "properties": {
    "schema_version": { "const": "report_md_v1" },
    "phase": {
      "type": "string",
      "pattern": "^phase[1-5]$"
    },
    "uid_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+(\\.\\d+)?$"
    },
    "uid_commit_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "report_path": {
      "type": "string",
      "description": "Path of the human-prose REPORT.md, relative to repo root."
    },
    "report_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "phase_status": {
      "type": "string",
      "enum": ["COMPLETE", "PARTIAL", "ABANDONED"],
      "description": "COMPLETE = all pre-registered F-conditions tested; PARTIAL = some tested, some deferred; ABANDONED = phase terminated early."
    },
    "falsification_scorecard": {
      "type": "object",
      "description": "One entry per pre-registered F-condition; same vocabulary as manifest_v1.json.",
      "minProperties": 1,
      "patternProperties": {
        "^F[0-9]+(['a-z]?)$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["verdict", "justification"],
          "properties": {
            "verdict": {
              "type": "string",
              "enum": [
                "PASS",
                "FAIL",
                "ABSTAIN_rank_deficient",
                "ABSTAIN_not_measured",
                "PARTIAL"
              ]
            },
            "justification": {
              "type": "string",
              "minLength": 1,
              "description": "One-sentence reason (max ~300 chars)."
            },
            "evidence_section": {
              "type": "string",
              "description": "Section number in the report that justifies the verdict, e.g. '§3.1'."
            }
          }
        }
      },
      "additionalProperties": false
    },
    "headline_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "3-5 sentence high-level summary (== §2.1 of REPORT.md)."
    },
    "aggregate_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "PASS",
        "FAIL",
        "ABSTAIN_rank_deficient",
        "ABSTAIN_not_measured",
        "PARTIAL"
      ],
      "properties": {
        "PASS": { "type": "integer", "minimum": 0 },
        "FAIL": { "type": "integer", "minimum": 0 },
        "ABSTAIN_rank_deficient": { "type": "integer", "minimum": 0 },
        "ABSTAIN_not_measured": { "type": "integer", "minimum": 0 },
        "PARTIAL": { "type": "integer", "minimum": 0 }
      }
    },
    "signatories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "date"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "date": { "type": "string", "format": "date" }
        }
      }
    }
  }
}
